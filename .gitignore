# ===== Secrets / lokale Umgebung =====
# Niemals echte Supabase- oder JWT-Zugangsdaten committen.
# Echte Secrets gehoeren in backend/.env (ignoriert), NICHT in versionierte Configs.
# Hinweis: backend/src/main/resources/application-local.yml ist bewusst eingecheckt –
# es enthaelt nur das H2-Dev-Profil (Dummy-Secret), keine echten Zugangsdaten.
.env
.env.*
!.env.example
*.local
secrets.properties

# ===== Java / Maven (Backend) =====
target/
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
*.war
*.nar
*.ear
hs_err_pid*
replay_pid*
# Maven-Wrapper-JAR wird beim ersten Lauf geladen
!.mvn/wrapper/maven-wrapper.jar

# ===== Node / Vite (Frontend) =====
node_modules/
dist/
dist-ssr/
*.tsbuildinfo
.vite/

# ===== IDE / OS =====
.idea/
.vscode/
*.iml
.DS_Store

# MS-Office-Sperrdateien
~$*

# ===== Archive (nicht committen) =====
*.zip
*.tar.gz
*.rar

/.claude