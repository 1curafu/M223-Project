# Vorlage fuer die lokalen Umgebungsvariablen des Backends.
# Kopieren nach .env und ausfuellen:  cp .env.example .env
# Vor dem Start laden:  set -a; source .env; set +a; ./mvnw spring-boot:run
#
# Werte stehen im Supabase-Dashboard:
#   Settings -> Database -> Connection string -> Tab "Session pooler"
#   (DB-Passwort dort ggf. ueber "Reset database password" setzen)

# JDBC-URL der Supabase-Postgres-DB (Host aus dem Dashboard einsetzen, sslmode beibehalten)
SUPABASE_DB_URL=jdbc:postgresql://<HOST>:5432/postgres?sslmode=require

# Beim Session-Pooler lautet der Benutzer "postgres.<project-ref>"
SUPABASE_DB_USER=postgres.bkxbbkvwudakpihlfzwj

# Datenbank-Passwort aus dem Dashboard
SUPABASE_DB_PASSWORD=<DEIN_DB_PASSWORT>

# JWT-Secret (mind. 32 Zeichen / 256 Bit) - frei waehlbar, nur nicht committen
JWT_SECRET=<EIN_LANGES_ZUFAELLIGES_GEHEIMNIS_MIN_32_ZEICHEN>
